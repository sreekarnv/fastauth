<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <style>
    body { margin: 0; padding: 0; background: #0d1117; font-family: 'Segoe UI', Arial, sans-serif; }
    .outer { width: 100%; padding: 48px 16px; box-sizing: border-box; }
    .card { width: 560px; margin: 0 auto; background: #161b22; border-radius: 8px; overflow: hidden; border: 1px solid #1d2330; }
    .header { background: #1c2128; padding: 24px 40px; border-bottom: 1px solid #1d2330; }
    .brand { margin: 0; font-size: 15px; font-weight: 700; color: #00d4ff; letter-spacing: 0.02em; }
    .body { padding: 40px; }
    h1 { margin: 0 0 16px; font-size: 24px; font-weight: 700; color: #e6edf3; letter-spacing: -0.02em; }
    p { margin: 0 0 28px; font-size: 15px; line-height: 1.6; color: #8b949e; }
    .btn { display: inline-block; padding: 12px 28px; background: #00d4ff; color: #0d1117; text-decoration: none; border-radius: 6px; font-size: 14px; font-weight: 600; letter-spacing: 0.01em; }
    .note { margin: 32px 0 0; font-size: 13px; color: #8b949e; }
    .footer { padding: 20px 40px; border-top: 1px solid #1d2330; }
    .footer p { font-size: 12px; color: #30363d; }
    .footer a { color: #67e8f9; text-decoration: none; word-break: break-all; }
  </style>
</head>
<body>
  <div class="outer">
    <div class="card">
      <div class="header">
        <p class="brand">FastAuth Example</p>
      </div>
      <div class="body">
        <h1>Reset your password</h1>
        <p>Hi {{ name }}, we received a request to reset your password. This link expires in {{ expires_in_minutes }} minutes.</p>
        <a href="{{ url }}" class="btn">Reset Password</a>
        <p class="note">Didn't request this? No action is needed — your password remains unchanged.</p>
      </div>
      <div class="footer">
        <p>Or copy this link into your browser:<br><a href="{{ url }}">{{ url }}</a></p>
      </div>
    </div>
  </div>
</body>
</html>
